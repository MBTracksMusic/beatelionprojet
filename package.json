{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "install:contract": "npm --prefix contract-service install",
    "build:contract": "npm --prefix contract-service ci && npm --prefix contract-service run build",
    "build": "npm run build:contract && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:contracts": "node --test tests/integration/contracts-immutability.test.mjs",
    "test:contract-runtime": "node --test tests/unit/contract-generation-runtime.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "supabase:types": "supabase gen types typescript --linked --schema public > src/lib/supabase/database.types.ts",
    "supabase:deploy:get-producer-plans:public": "supabase functions deploy get-producer-plans --no-verify-jwt",
    "supabase:deploy:stripe-webhook:public": "supabase functions deploy stripe-webhook --no-verify-jwt",
    "supabase:deploy:create-checkout:private": "supabase functions deploy create-checkout",
    "supabase:deploy:producer-checkout:private": "supabase functions deploy producer-checkout",
    "supabase:deploy:create-portal-session:private": "supabase functions deploy create-portal-session",
    "supabase:deploy:get-master-url:private": "supabase functions deploy get-master-url",
    "supabase:deploy:get-contract-url:private": "supabase functions deploy get-contract-url"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.6",
    "@ffmpeg/util": "^0.12.1",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@sentry/deno": "^10.43.0",
    "@sentry/node": "^10.43.0",
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.344.0",
    "pdfkit": "^0.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.0",
    "resend": "^6.9.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.18",
    "cypress": "^15.9.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  }
}
