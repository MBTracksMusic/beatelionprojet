# Supabase Configuration
# Get these from: https://supabase.com > Your Project > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
VITE_SUPABASE_AUDIO_BUCKET=beats-audio
VITE_SUPABASE_COVER_BUCKET=beats-covers
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
# Legacy fallback supported by contact-submit:
# HCAPTCHA_SECRET=your_hcaptcha_secret_key

# Resend Email (optional - for email notifications)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="BeatElion <noreply@beatelion.com>"
CONTACT_TO_EMAIL="contact@beatelion.com"
# Optional reply-to identities
# SUPPORT_EMAIL="support@beatelion.com"
# SOCIAL_EMAIL="social@beatelion.com"
# CONTACT_EMAIL_RATE_LIMIT_SECONDS=900

# Contract API security (server-to-server secret)
CONTRACT_SERVICE_SECRET=your_contract_service_secret
# Preferred: full canonical endpoint to API generator.
CONTRACT_GENERATE_ENDPOINT=https://your-domain.com/api/generate-contract
# Legacy fallback (deprecated): if CONTRACT_GENERATE_ENDPOINT is not set,
# Edge Functions will use CONTRACT_SERVICE_URL + "/generate-contract".
# CONTRACT_SERVICE_URL=https://your-domain.com/api

# Stripe (server-side)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRODUCER_PRICE_ID=price_xxx

# Observability (backend: Edge Functions, API routes, workers)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
ENVIRONMENT=production
# Optional
# SENTRY_TRACES_SAMPLE_RATE=0.1
