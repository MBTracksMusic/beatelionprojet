# =========================
# FRONTEND (Vite / browser-exposed)
# =========================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
VITE_SITE_URL=https://www.beatelion.com
VITE_SUPABASE_COVER_BUCKET=beats-covers
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional frontend overrides with in-app fallbacks
# VITE_SUPABASE_AUDIO_BUCKET=beats-audio
# VITE_SUPABASE_AVATAR_BUCKET=avatars
# VITE_SUPABASE_MASTER_BUCKET=beats-masters
# VITE_SUPABASE_WATERMARKED_BUCKET=beats-watermarked
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional - comma-separated list of emails allowed during maintenance mode
# Use in .env.local only (never commit to repo)
# VITE_MAINTENANCE_WHITELIST=test@example.com,admin@example.com

# =========================
# BACKEND (Supabase functions / API routes / workers)
# =========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_PROJECT_REF=your_project_ref
# Supabase CLI remote DB access only. Use your Postgres database password,
# never an anon key or service_role key.
SUPABASE_DB_PASSWORD=your_postgres_database_password
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
CONTRACT_SERVICE_SECRET=your_contract_service_secret
CONTRACT_GENERATE_ENDPOINT=https://your-domain.com/api/generate-contract

# Legacy fallback supported by contract generation helpers
# CONTRACT_SERVICE_URL=https://your-domain.com/api

# =========================
# STRIPE
# =========================
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRODUCER_PRICE_ID=price_xxx

# =========================
# EMAIL / NOTIFICATIONS
# =========================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL="BeatElion <contact@beatelion.com>"
CONTACT_TO_EMAIL="contact@beatelion.com"

# Optional reply-to identities
# SUPPORT_EMAIL="support@beatelion.com"
# SOCIAL_EMAIL="social@beatelion.com"

# =========================
# OBSERVABILITY
# =========================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
